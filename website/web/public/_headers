# Cloudflare Pages reads this file from the publish root (dist/_headers).
# Astro copies everything under public/ to dist/ at build time.
#
# Rule order: more-specific paths first; the catch-all sits at the bottom.
# Cloudflare Pages auto-purges the edge cache on every deploy, so edge
# (`s-maxage`) values can be aggressive — a stale edge entry never survives
# past the next push to main.

# --- Fingerprinted Astro output: bundles + per-component CSS ---
# Filenames carry a content hash, so the URL itself is the cache key.
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# --- Vendored fonts (woff2) ---
# Subsetted Geist Variable + JetBrains Mono Variable. Filenames are stable;
# replace the file or rename it when re-vendoring.
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# --- Static imagery (hero art, blog images, docs diagrams, OG card) ---
/img/*
  Cache-Control: public, max-age=31536000, immutable

# --- Pagefind search index ---
# Regenerated on every build; each fragment file is content-hashed internally.
/pagefind/*
  Cache-Control: public, max-age=31536000, immutable

# --- Favicons + web manifest ---
# Filenames are not hashed, so cap browser cache at 1 day to allow swaps.
/favicon.ico
  Cache-Control: public, max-age=86400
/favicon.svg
  Cache-Control: public, max-age=86400
/favicon-32x32.png
  Cache-Control: public, max-age=86400
/apple-touch-icon.png
  Cache-Control: public, max-age=86400
/android-chrome-192x192.png
  Cache-Control: public, max-age=86400
/android-chrome-512x512.png
  Cache-Control: public, max-age=86400
/site.webmanifest
  Cache-Control: public, max-age=86400
  Content-Type: application/manifest+json; charset=utf-8

# --- Sitemap (regenerated each build by @astrojs/sitemap) ---
/sitemap-index.xml
  Cache-Control: public, max-age=3600, must-revalidate
/sitemap-*.xml
  Cache-Control: public, max-age=3600, must-revalidate

# --- Everything else: HTML pages and any unmatched asset ---
# Browser revalidates after 10 minutes; the edge serves cached HTML for 24
# hours (a deploy purges this anyway); stale-while-revalidate keeps the page
# fast for repeat visitors during the brief revalidation window.
#
# Baseline security headers ride along here so every HTML response carries
# them without needing a separate Cloudflare Transform Rule.
/*
  Cache-Control: public, max-age=600, s-maxage=86400, stale-while-revalidate=604800
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
