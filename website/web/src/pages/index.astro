---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/nav/SiteHeader.astro';
import Hero from '../components/home/Hero.astro';
import ExampleGrid from '../components/home/ExampleGrid.astro';
import CausalStack from '../components/home/CausalStack.astro';
import WhyDeepCausality from '../components/home/WhyDeepCausality.astro';
import JoinCommunity from '../components/home/JoinCommunity.astro';
import SectionDivider from '../components/home/SectionDivider.astro';
import { GITHUB_URL, DISCORD_URL } from '../consts';

const siteUrl = new URL('/', Astro.site).toString();
const logoUrl = new URL('/img/logo-color.png', Astro.site).toString();
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${siteUrl}#organization`,
    name: 'DeepCausality',
    alternateName: 'Deep Causality',
    url: siteUrl,
    logo: logoUrl,
    description:
      'Open-source Rust framework for dynamic causality. Causal reasoning for advanced systems where time, context, and rules evolve. Hosted at the Linux Foundation for AI & Data.',
    foundingDate: '2023',
    sameAs: [
      GITHUB_URL,
      'https://lfaidata.foundation/projects/deepcausality/',
      DISCORD_URL,
      'https://lists.lfaidata.foundation/g/DeepCausality-announce',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${siteUrl}#website`,
    url: siteUrl,
    name: 'DeepCausality',
    description:
      'DeepCausality is a Rust framework for dynamic causality. Causal reasoning for advanced systems where time, context, and rules evolve.',
    publisher: { '@id': `${siteUrl}#organization` },
    inLanguage: 'en',
  },
];
---
<BaseLayout
  title="DeepCausality — Computational Causality Framework in Rust"
  description="DeepCausality is an open-source Rust framework for computational causality. Causal reasoning, counterfactuals, and causal discovery for dynamic systems where time, context, and rules evolve."
>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <SiteHeader />
  <Hero />
  <SectionDivider />
  <CausalStack />
  <SectionDivider />
  <ExampleGrid />
  <SectionDivider />
  <WhyDeepCausality />
  <SectionDivider />
  <JoinCommunity />
</BaseLayout>
