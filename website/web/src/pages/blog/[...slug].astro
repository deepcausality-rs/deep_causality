---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/nav/SiteHeader.astro';

export async function getStaticPaths() {
  const entries = await getCollection('blog', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id.replace(/^en\//, '').replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, author, date } = entry.data;
const fmtDate = date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageUrl = new URL('/img/social-share.jpg', Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description: description ?? title,
  author: { '@type': 'Person', name: author },
  datePublished: date.toISOString(),
  dateModified: date.toISOString(),
  image: ogImageUrl,
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  publisher: {
    '@type': 'Organization',
    name: 'DeepCausality',
    url: new URL('/', Astro.site).toString(),
  },
};
---
<BaseLayout title={`${title} — DeepCausality`} description={description ?? title}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <SiteHeader />
  <article class="post">
    <header>
      <p class="eyebrow">Blog</p>
      <h1>{title}</h1>
      <p class="byline"><span>{author}</span><span aria-hidden="true">·</span><time datetime={date.toISOString()}>{fmtDate}</time></p>
    </header>
    <div class="prose">
      <Content />
    </div>
    <nav class="back" aria-label="Back to blog">
      <a href="/blog/">&larr; All posts</a>
    </nav>
  </article>

  <style is:global>
    .post { max-width: var(--w-prose); margin: 0 auto; padding: var(--space-7) var(--space-4); }
    @media (min-width: 720px) { .post { padding: var(--space-9) var(--space-5); } }
    .post header { margin-bottom: var(--space-6); }
    .post .eyebrow {
      margin: 0;
      font-size: var(--t-eyebrow); letter-spacing: var(--ls-eyebrow);
      text-transform: uppercase; color: var(--fg-2);
    }
    .post h1 { margin: var(--space-2) 0 var(--space-3) 0; font-size: var(--t-h1); line-height: var(--lh-h1); letter-spacing: var(--ls-h1); }
    .post .byline { margin: 0; color: var(--fg-2); font-size: var(--t-body-sm); display: flex; gap: var(--space-2); align-items: baseline; }

    .post .prose p,
    .post .prose li { color: var(--fg-1); }
    .post .prose p { max-width: var(--measure); margin: 0 0 var(--space-4) 0; }
    .post .prose h2 { margin: var(--space-7) 0 var(--space-3) 0; }
    .post .prose h3 { margin: var(--space-6) 0 var(--space-2) 0; }
    .post .prose ul, .post .prose ol { padding-left: var(--space-5); margin: 0 0 var(--space-4) 0; }
    .post .prose li { margin: var(--space-2) 0; }
    .post .prose img {
      max-width: 100%;
      height: auto;
      display: block;
      margin: var(--space-5) 0;
      border-radius: var(--radius-md);
      border: 1px solid var(--line-1);
    }
    .post .prose pre {
      background: var(--bg-2);
      border: 1px solid var(--line-1);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      overflow: auto;
      margin: var(--space-4) 0;
      font-size: var(--t-mono-block);
      line-height: var(--lh-body);
    }
    .post .prose pre code { background: transparent; padding: 0; }
    .post .prose blockquote {
      margin: var(--space-4) 0;
      padding: var(--space-3) var(--space-5);
      border-left: 3px solid var(--accent);
      background: var(--bg-1);
      color: var(--fg-1);
    }
    .post .prose .table-wrap { overflow-x: auto; margin: var(--space-4) 0; }
    .post .prose table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--t-body-sm);
      background: var(--bg-1);
      border: 1px solid var(--line-1);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .post .prose thead { background: var(--bg-2); }
    .post .prose th,
    .post .prose td {
      padding: var(--space-2) var(--space-3);
      text-align: left;
      border-bottom: 1px solid var(--line-1);
      color: var(--fg-1);
      vertical-align: top;
    }
    .post .prose th { color: var(--fg-0); font-weight: 600; }
    .post .prose tbody tr:last-child td { border-bottom: 0; }
    .post .prose tbody tr:hover { background: var(--bg-2); }

    .post .back { margin-top: var(--space-8); }
    .post .back a { color: var(--fg-1); border-bottom: none; }
    .post .back a:hover { color: var(--fg-0); }
  </style>
</BaseLayout>
