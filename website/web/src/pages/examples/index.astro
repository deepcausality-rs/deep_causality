---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/nav/SiteHeader.astro';
import ExamplesList from '../../components/examples/ExamplesList.astro';
import { GITHUB_URL } from '../../consts';

const entries = (await getCollection('examples')).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<BaseLayout title="Examples — DeepCausality" description="All examples across foundations, aerospace, physics, medicine, and mathematics.">
  <SiteHeader />
  <section class="ex-index">
    <header>
      <p class="eyebrow">Examples</p>
      <h1>One framework, many fields</h1>
      <p class="lede">Pick the field that looks closest to the problem you have in front of you. Each page carries a runnable snippet, a walkthrough, and pointers into the docs.</p>
      <nav class="cat-row" aria-label="Example categories">
        <a href="/examples/foundations/">Foundations</a>
        <a href="/examples/aerospace/">Aerospace</a>
        <a href="/examples/physics/">Physics</a>
        <a href="/examples/medicine/">Medicine</a>
        <a href="/examples/mathematics/">Mathematics</a>
      </nav>
    </header>

    <ExamplesList entries={entries} />

    <aside class="more">
      <p>
        The detail pages above each cover one example in depth. The repository
        ships many more, including avionics, materials science, classical-causality
        walkthroughs (Pearl SCM, DBN, Granger, RCM), additional medical scenarios
        (aneurysm risk, decompression, epilepsy), and a much wider physics catalog
        (gauge theories, gravitational waves, the IKKT matrix model, quantum
        counterfactuals).
      </p>
      <p>
        <a href={`${GITHUB_URL}/tree/main/examples`}>
          Browse the full <code>examples/</code> tree on GitHub &rarr;
        </a>
      </p>
    </aside>
  </section>

  <style>
    .ex-index { max-width: var(--w-page); margin: 0 auto; padding: var(--space-7) var(--space-4); }
    @media (min-width: 720px) { .ex-index { padding: var(--space-9) var(--space-5); } }
    .ex-index header { max-width: 56ch; margin-bottom: var(--space-6); }
    .eyebrow {
      margin: 0;
      font-size: var(--t-eyebrow); letter-spacing: var(--ls-eyebrow);
      text-transform: uppercase; color: var(--fg-2);
    }
    h1 { margin: var(--space-2) 0 var(--space-3) 0; }
    .lede { color: var(--fg-1); }
    .cat-row {
      display: flex; flex-wrap: wrap; gap: var(--space-2);
      margin-top: var(--space-4);
    }
    .cat-row a {
      display: inline-block;
      padding: var(--space-1) var(--space-3);
      border: 1px solid var(--line-1);
      border-radius: var(--radius-pill);
      color: var(--fg-1);
      border-bottom: 1px solid var(--line-1);
      font-size: var(--t-body-sm);
    }
    .cat-row a:hover { color: var(--fg-0); border-color: var(--line-2); }

    .more {
      margin-top: var(--space-7);
      padding-top: var(--space-6);
      border-top: 1px solid var(--line-1);
    }
    .more p { color: var(--fg-1); max-width: var(--measure); margin: 0 0 var(--space-3) 0; }
    .more code { background: var(--bg-3); padding: 0 0.3em; border-radius: var(--radius-sm); }
  </style>
</BaseLayout>
