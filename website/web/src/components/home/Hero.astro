---
// Asymmetric split hero. Text left (7/12), hero art right (5/12).
// Stacks below 900px; on stack, the raster moves above the text.
---
<section class="hero">
  <div class="hero-inner">
    <div class="hero-text">
      <h1>DeepCausality</h1>
      <p class="tagline">Dynamic causality for advanced systems.</p>
      <p class="sub">
        A causal-reasoning library for engineering systems where time, context, and rules evolve.
        Built around three primitives: the causal monad, the causaloid, and the context.
      </p>
      <div class="cta">
        <a class="btn btn-primary" href="/docs/getting-started/install/">Get started</a>
        <a class="btn btn-ghost" href="https://github.com/deepcausality-rs/deep_causality">View on GitHub <span aria-hidden="true">→</span></a>
      </div>
    </div>
    <div class="hero-art-frame reticle-host" aria-hidden="true">
      <span class="reticle reticle-tl"></span>
      <span class="reticle reticle-tr"></span>
      <span class="reticle reticle-bl"></span>
      <span class="reticle reticle-br"></span>
      <img src="/img/frontpage-art.webp" alt="" loading="eager" decoding="async" width="1200" height="630" />
    </div>
  </div>
</section>

<style>
  /* Mobile-first: stack, hero art above text. Expand to 7/5 split at ≥900px. */
  .hero { padding: var(--space-7) 0; }
  .hero-inner {
    max-width: var(--w-wide);
    margin: 0 auto;
    padding: 0 var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    align-items: center;
  }
  .hero-inner > * { min-width: 0; }
  .hero-text { display: flex; flex-direction: column; gap: var(--space-4); max-width: 56ch; }

  @media (min-width: 900px) {
    .hero { padding: var(--space-9) 0 var(--space-7); }
    .hero-inner {
      grid-template-columns: 7fr 5fr;
      gap: var(--space-8);
      padding: 0 var(--space-5);
    }
    .hero-art-frame { order: 0; }
  }
  .eyebrow {
    margin: 0;
    font-size: var(--t-eyebrow); letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase; color: var(--fg-2);
  }
  h1 {
    /* Fluid display size: smaller on phones, scales up on desktop. */
    font-size: clamp(2.25rem, 6vw + 0.5rem, 3.75rem);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    margin: 0;
  }
  .tagline {
    margin: 0;
    font-size: var(--t-h3); line-height: var(--lh-h3); letter-spacing: var(--ls-h3);
    color: var(--fg-1);
  }
  .sub { margin: var(--space-2) 0 0 0; color: var(--fg-1); max-width: 52ch; }
  .cta { display: flex; gap: var(--space-3); margin-top: var(--space-3); flex-wrap: wrap; }

  .btn {
    height: 44px;
    padding: 0 var(--space-5);
    display: inline-flex; align-items: center; gap: var(--space-2);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-weight: 540;
    text-decoration: none;
    transition: transform var(--dur-fast) var(--ease-out),
                background-color var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out),
                box-shadow var(--dur-fast) var(--ease-out);
  }
  .btn:active { transform: translateY(1px); }
  .btn-primary {
    background: var(--accent);
    color: var(--accent-ink);
    border-color: var(--accent);
    box-shadow: 0 1px 0 0 color-mix(in srgb, var(--accent) 60%, black) inset,
                0 1px 2px 0 color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 90%, white);
    border-color: color-mix(in srgb, var(--accent) 90%, white);
    border-bottom-color: color-mix(in srgb, var(--accent) 90%, white);
  }
  .btn-ghost {
    color: var(--fg-0);
    border-color: var(--fg-2);
    background: transparent;
  }
  .btn-ghost:hover {
    border-color: var(--fg-1);
    border-bottom-color: var(--fg-1);
    color: var(--fg-0);
    background: color-mix(in srgb, var(--fg-2) 8%, transparent);
  }

  .hero-art-frame {
    border: 1px solid var(--line-1);
    border-radius: var(--radius-lg);
    overflow: hidden;
    /* Ambient cyan halo + the existing tinted drop shadow. The halo is a
       soft outer glow tied to --accent so it picks up the per-theme accent
       automatically; in light mode the deeper teal renders as a quiet wash. */
    box-shadow:
      0 0 80px -28px color-mix(in srgb, var(--accent) 38%, transparent),
      var(--shadow-2);
    background: var(--bg-1);
  }
  /* Reticle corners on the hero frame use the larger radius. */
  .hero-art-frame > .reticle-tl { border-top-left-radius: var(--radius-lg); }
  .hero-art-frame > .reticle-tr { border-top-right-radius: var(--radius-lg); }
  .hero-art-frame > .reticle-bl { border-bottom-left-radius: var(--radius-lg); }
  .hero-art-frame > .reticle-br { border-bottom-right-radius: var(--radius-lg); }
  .hero-art-frame img { display: block; width: 100%; height: auto; }

  /* Stack order on small viewports: art above text so the brand image is the first thing seen. */
  .hero-art-frame { order: -1; }
</style>
