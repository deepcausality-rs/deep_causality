---
// Hairline section divider with three node dots, drawn once on intersect.
// Replaces the plain `border-top: 1px solid var(--line-1)` between home sections.
---
<div class="section-divider" role="presentation">
  <svg viewBox="0 0 100 4" preserveAspectRatio="none" aria-hidden="true" data-anim-draw>
    <line x1="0" y1="2" x2="100" y2="2" pathLength="100" />
    <circle cx="25" cy="2" r="0.55" />
    <circle cx="50" cy="2" r="0.55" />
    <circle cx="75" cy="2" r="0.55" />
  </svg>
</div>
