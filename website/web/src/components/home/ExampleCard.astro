---
import { Code } from 'astro:components';
import type { Example } from './examples';

interface Props { example: Example; index: number }
const { example, index } = Astro.props;

// Per-slug monoline glyphs (16×16). Never an emoji. Fallback is a small node-link mark.
const glyphs: Record<string, string> = {
  'aerospace-flight-envelope':
    '<path d="M2 11 L8 4 L14 11 Z"/><path d="M8 4 L8 14"/><circle cx="8" cy="11" r="1.2"/>',
  'sensor-monitoring-csm':
    '<path d="M2 8 L5 8 L7 4 L9 12 L11 8 L14 8"/>',
  'async-event-inference':
    '<circle cx="8" cy="8" r="5.5"/><path d="M8 4 L8 8 L11 9.5"/>',
  'biomedical-tumor-treatment':
    '<path d="M3 3 C 7 5, 9 11, 13 13 M13 3 C 9 5, 7 11, 3 13"/><circle cx="3" cy="3" r="1"/><circle cx="13" cy="3" r="1"/><circle cx="3" cy="13" r="1"/><circle cx="13" cy="13" r="1"/>',
  'physics-maxwell':
    '<circle cx="8" cy="8" r="2"/><ellipse cx="8" cy="8" rx="6" ry="2.5"/><ellipse cx="8" cy="8" rx="6" ry="2.5" transform="rotate(60 8 8)"/><ellipse cx="8" cy="8" rx="6" ry="2.5" transform="rotate(120 8 8)"/>',
  'pearl-counterfactual':
    '<circle cx="4" cy="4" r="1.4"/><circle cx="12" cy="8" r="1.4"/><circle cx="4" cy="12" r="1.4"/><path d="M5 5 L11 7"/><path d="M11 9 L5 11"/>',
};
const fallback = '<circle cx="4" cy="8" r="1.4"/><circle cx="12" cy="8" r="1.4"/><path d="M5.5 8 L10.5 8"/>';
const glyph = glyphs[example.slug] ?? fallback;

---
<a class="example-card" href={`/examples/${example.slug}/`}>
  <header class="ec-head">
    <span class="ec-eyebrow">{example.domain}</span>
    <svg class="ec-glyph" width="16" height="16" viewBox="0 0 16 16" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={glyph} />
  </header>
  <h3 class="ec-headline">{example.headline}</h3>
  <div class="ec-code">
    <Code code={example.snippet} lang="rust" themes={{ light: 'github-light', dark: 'github-dark' }} defaultColor={false} />
  </div>
  <footer class="ec-foot">
    <span>Open example</span>
    <span aria-hidden="true">→</span>
  </footer>
</a>

<style>
  .example-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    padding: var(--space-5);
    background: var(--bg-1);
    border: 1px solid var(--line-1);
    border-radius: var(--radius-md);
    color: var(--fg-0);
    box-shadow: var(--shadow-1);
    text-decoration: none;
    min-width: 0; /* critical: lets a grid item shrink below its content's intrinsic width */
    height: 100%; /* uniform card heights inside a stretching grid row */
    transition: transform var(--dur-med) var(--ease-out), border-color var(--dur-med) var(--ease-out);
  }
  .example-card:hover {
    transform: translate3d(0, -2px, 0);
    border-color: var(--line-2);
  }
  .example-card:focus-visible { outline-offset: 4px; }

  .ec-head { display: flex; align-items: center; justify-content: space-between; }
  .ec-eyebrow {
    font-size: var(--t-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-1);
  }
  .ec-glyph { color: var(--accent); }

  .ec-headline {
    font-size: var(--t-h4);
    line-height: var(--lh-h4);
    color: var(--fg-0);
    margin: 0;
    font-weight: 540;
  }

  .ec-code {
    background: var(--bg-2);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    font-size: var(--t-mono-block);
    line-height: var(--lh-body);
    min-width: 0;
    overflow: hidden; /* the inner <pre> scrolls; the card itself never widens past the column */
    flex-grow: 1; /* claim vertical slack so all cards in the row end the same height */
    display: flex;
    flex-direction: column;
  }
  .ec-code :global(pre) {
    background: transparent !important;
    margin: 0;
    overflow-x: auto; /* horizontal scroll on the code, not on the card */
    flex-grow: 1;
  }
  .ec-code :global(code) { font-family: var(--font-mono); }

  .ec-foot {
    margin-top: auto;
    padding-top: var(--space-3);
    border-top: 1px solid var(--line-1);
    display: flex; justify-content: space-between; align-items: center;
    color: var(--accent);
    font-size: var(--t-body-sm);
  }
</style>
