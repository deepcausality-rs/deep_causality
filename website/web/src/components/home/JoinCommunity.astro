---
import { GITHUB_URL, DISCORD_URL } from '../../consts';
const links = [
  {
    name: 'GitHub',
    href: GITHUB_URL,
    body: 'Issues, pull requests, releases, and the full source. Star the repo to keep an eye on the project.',
    cta: 'View on GitHub',
    icon: 'github',
  },
  {
    name: 'Discord',
    href: DISCORD_URL,
    body: 'Real-time chat with maintainers and contributors. Drop in with questions, ideas, or use-cases.',
    cta: 'Join the server',
    icon: 'discord',
  },
];
---
<section class="community">
  <div class="community-inner">
    <h2>Join the community</h2>

    <div class="community-row">
      {links.map((l) => (
        <a class="community-card reticle-host" href={l.href} rel="noopener noreferrer" target="_blank">
          <span class="reticle reticle-tl" aria-hidden="true"></span>
          <span class="reticle reticle-tr" aria-hidden="true"></span>
          <span class="reticle reticle-bl" aria-hidden="true"></span>
          <span class="reticle reticle-br" aria-hidden="true"></span>
          <span class="community-icon" aria-hidden="true">
            {l.icon === 'github' ? (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 .5a11.5 11.5 0 0 0-3.63 22.42c.57.1.78-.25.78-.55v-2.06c-3.18.69-3.86-1.36-3.86-1.36-.52-1.34-1.27-1.7-1.27-1.7-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.34.96.1-.74.4-1.25.73-1.54-2.54-.29-5.21-1.27-5.21-5.66 0-1.25.45-2.27 1.18-3.07-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.94 10.94 0 0 1 5.74 0c2.19-1.48 3.15-1.17 3.15-1.17.62 1.58.23 2.75.11 3.04.74.8 1.18 1.82 1.18 3.07 0 4.4-2.68 5.37-5.23 5.65.41.36.78 1.06.78 2.13v3.16c0 .3.21.66.79.55A11.5 11.5 0 0 0 12 .5Z"/>
              </svg>
            ) : (
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.317 4.3698a19.7913 19.7913 0 0 0-4.8851-1.5152.0741.0741 0 0 0-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 0 0-.0785-.037 19.7363 19.7363 0 0 0-4.8852 1.515.0699.0699 0 0 0-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 0 0 .0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 0 0 .0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 0 0-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 0 1-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 0 1 .0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 0 1 .0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 0 1-.0066.1276 12.2986 12.2986 0 0 1-1.873.8914.0766.0766 0 0 0-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 0 0 .0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 0 0 .0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 0 0-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189Z"/>
              </svg>
            )}
          </span>
          <h3>{l.name}</h3>
          <p>{l.body}</p>
          <span class="community-cta">{l.cta} <span aria-hidden="true">→</span></span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .community { padding: var(--space-8) 0; }
  .community-inner { max-width: var(--w-page); margin: 0 auto; padding: 0 var(--space-4); }
  @media (min-width: 720px) { .community { padding: var(--space-9) 0; } .community-inner { padding: 0 var(--space-5); } }

  h2 { margin: 0 0 var(--space-7) 0; text-align: center; }

  .community-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
    max-width: 880px;
    margin: 0 auto;
  }
  @media (min-width: 720px) {
    .community-row { grid-template-columns: repeat(2, 1fr); gap: var(--space-6); }
  }

  .community-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-5) var(--space-4);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-1) 70%, transparent) 0%,
        var(--bg-1) 100%
      );
    border: 1px solid var(--line-1);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-1);
    color: var(--fg-0);
    border-bottom: 1px solid var(--line-1);
    transition: border-color var(--dur-fast) var(--ease-out),
                background var(--dur-fast) var(--ease-out),
                transform var(--dur-fast) var(--ease-out);
  }
  .community-card:hover {
    border-color: var(--line-2);
    border-bottom-color: var(--line-2);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--bg-1) 70%, transparent) 0%,
        color-mix(in srgb, var(--bg-1) 92%, var(--accent)) 100%
      );
    transform: translateY(-1px);
  }

  .community-icon {
    display: inline-grid;
    place-items: center;
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--accent) 12%, transparent);
    color: var(--accent);
  }

  .community-card h3 { margin: 0; font-size: var(--t-h3); }
  .community-card p { margin: 0; color: var(--fg-1); max-width: 44ch; }
  .community-cta { color: var(--accent); font-size: var(--t-body-sm); margin-top: var(--space-1); }
  .community-card:hover h3 { color: var(--accent); }
</style>
