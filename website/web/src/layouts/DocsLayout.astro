---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/nav/SiteHeader.astro';
import DocsSidebar from '../components/docs/DocsSidebar.astro';

interface Props {
  title: string;
  description?: string;
  sectionLabel?: string;
}
const { title, description, sectionLabel } = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const siteUrl = new URL('/', Astro.site).toString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'TechArticle',
  headline: title,
  description: description ?? title,
  inLanguage: 'en',
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  author: { '@type': 'Organization', name: 'DeepCausality', url: siteUrl },
  publisher: {
    '@type': 'Organization',
    name: 'DeepCausality',
    url: siteUrl,
    logo: new URL('/img/logo-color.png', Astro.site).toString(),
  },
};
---
<BaseLayout title={`${title} — DeepCausality`} description={description ?? title}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(jsonLd)} />
  <SiteHeader />
  <div class="docs-shell">
    <DocsSidebar />
    <article class="docs-article">
      <button
        class="docs-menu-toggle"
        type="button"
        aria-label="Open documentation menu"
        aria-controls="docs-menu-drawer"
        aria-expanded="false"
        data-docs-menu-toggle
      >
        <svg width="18" height="18" viewBox="0 0 20 20" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
          <path d="M3 5 H17 M3 10 H17 M3 15 H17"/>
        </svg>
        <span>Docs menu</span>
      </button>
      <header class="doc-head">
        {sectionLabel && <p class="eyebrow">{sectionLabel}</p>}
        <h1>{title}</h1>
      </header>
      <div class="doc-prose">
        <slot />
      </div>
    </article>
  </div>

  <style is:global>
    .docs-shell {
      max-width: var(--w-doc);
      margin: 0 auto;
      padding: 0 var(--space-4);
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
    }
    @media (min-width: 900px) {
      .docs-shell {
        padding: 0 var(--space-5);
        grid-template-columns: 240px 1fr;
        gap: var(--space-8);
      }
    }
    .docs-article {
      padding: var(--space-7) 0;
      min-width: 0;
    }
    @media (min-width: 900px) {
      .docs-article { padding: var(--space-9) 0; }
    }

    /* Mobile-only hamburger that opens the docs drawer. Placed inline
       above the article header so it never participates in the desktop
       grid layout. */
    .docs-menu-toggle {
      display: inline-flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-3);
      margin: 0 0 var(--space-5) 0;
      background: transparent;
      color: var(--fg-1);
      border: 1px solid var(--line-1);
      border-radius: var(--radius-sm);
      font: inherit;
      font-size: var(--t-body-sm);
      cursor: pointer;
      transition: color var(--dur-fast) var(--ease-out),
                  border-color var(--dur-fast) var(--ease-out);
    }
    .docs-menu-toggle:hover { color: var(--fg-0); border-color: var(--line-2); }
    .docs-menu-toggle:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
    @media (min-width: 900px) {
      .docs-menu-toggle { display: none; }
    }
    .doc-head { margin-bottom: var(--space-6); }
    .doc-head .eyebrow {
      margin: 0 0 var(--space-2) 0;
      font-size: var(--t-eyebrow);
      letter-spacing: var(--ls-eyebrow);
      text-transform: uppercase;
      color: var(--fg-2);
    }
    .doc-head h1 { margin: 0; }
    .doc-prose { max-width: var(--w-prose); }
    .doc-prose p,
    .doc-prose li { color: var(--fg-1); }
    .doc-prose p { max-width: var(--measure); margin: 0 0 var(--space-4) 0; }
    .doc-prose h2 { margin: var(--space-7) 0 var(--space-3) 0; }
    .doc-prose h3 { margin: var(--space-6) 0 var(--space-2) 0; }
    .doc-prose ul, .doc-prose ol { padding-left: var(--space-5); margin: 0 0 var(--space-4) 0; }
    .doc-prose li { margin: var(--space-2) 0; }
    .doc-prose pre {
      background: var(--bg-2);
      border: 1px solid var(--line-1);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      overflow: auto;
      margin: var(--space-4) 0;
      font-size: var(--t-mono-block);
      line-height: var(--lh-body);
    }
    .doc-prose pre code { background: transparent; padding: 0; }
    .doc-prose blockquote {
      margin: var(--space-4) 0;
      padding: var(--space-3) var(--space-5);
      border-left: 3px solid var(--accent);
      background: var(--bg-1);
      color: var(--fg-1);
    }
    .doc-prose blockquote p:last-child { margin-bottom: 0; }
    .doc-prose table {
      width: 100%;
      border-collapse: collapse;
      font-size: var(--t-body-sm);
      background: var(--bg-1);
      border: 1px solid var(--line-1);
      border-radius: var(--radius-md);
      overflow: hidden;
      margin: var(--space-4) 0;
    }
    .doc-prose thead { background: var(--bg-2); }
    .doc-prose th,
    .doc-prose td {
      padding: var(--space-2) var(--space-3);
      text-align: left;
      border-bottom: 1px solid var(--line-1);
      color: var(--fg-1);
      vertical-align: top;
    }
    .doc-prose th { color: var(--fg-0); font-weight: 600; }
    .doc-prose tbody tr:last-child td { border-bottom: 0; }
    .doc-prose tbody tr:hover { background: var(--bg-2); }
  </style>
</BaseLayout>
