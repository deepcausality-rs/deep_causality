---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/nav/SiteHeader.astro';
import { GITHUB_URL } from '../../consts';

const title = 'Tutorial — DeepCausality CFD';
const description =
  'A guided walk through the plasma-blackout programs: three walks, seventeen stations, each showing the committed code, the reason it is written that way, and the alternative that was rejected.';

const stages = (await getCollection('tutorial')).sort(
  (a, b) => a.data.stage - b.data.stage
);

const FAMILY_URL = `${GITHUB_URL}/tree/main/examples/avionics_examples/cfd/plasma_blackout`;
---
<BaseLayout title={title} description={description} path="/tutorial/">
  <SiteHeader slot="header" />

  <article class="page tpage">
    <header class="thead">
      <p class="eyebrow">Tutorial</p>
      <h1>Reading the plasma-blackout programs</h1>
      <p class="lede">
        Three walks through code that is committed, runs, and gates itself.
        Each station gives what the program does, the reason for that
        construction, and the failure mode of the alternative.
      </p>
    </header>

    <section class="tsection">
      <h2>What you will be able to do</h2>
      <div class="prose">
        <p>
          After the third walk you can open an unfamiliar
          <code>CfdFlow</code> program and answer four questions about it:
          where its leg boundaries sit and why, whether its counterfactual
          forks a state or alternates a world, what its gates would catch, and
          which of its constants record a measurement rather than a
          preference.
        </p>
        <p>
          The subject is a reentry vehicle that enters at Mach 25, loses every
          GNSS link to its own plasma sheath, navigates without one, and lands
          under a retro burn. That problem requires fluid dynamics, plasma
          chemistry, navigation, and control to be correct simultaneously,
          which is the multidisciplinary coupling the NASA CFD Vision 2030
          Study names as an open challenge. The <a href="/why/">Why page</a>
          carries that mapping in full.
        </p>
      </div>
    </section>

    <section class="tsection">
      <h2>Before you start</h2>
      <div class="prose">
        <p>
          The walks require a Rust toolchain and a clone of the repository.
          They assume no prior familiarity with the crate, and cover reentry
          physics only where a design decision depends on it.
        </p>
      </div>
      <pre class="cmd"><code>git clone https://github.com/deepcausality-rs/deep_causality.git
cd deep_causality</code></pre>
      <div class="prose">
        <p>
          Each walk opens by running its program. Run them in order the first
          time, because walk 2 writes the table walk 3 reads. Total runtime is
          about eleven minutes. Every number quoted in the walks comes from a
          committed run output, so your output should match.
        </p>
      </div>
    </section>

    <section class="tsection" data-rise>
      <h2>The three walks</h2>

      <ol class="pipeline">
        {stages.map((s) => (
          <li class="pstage rise" style={`--i:${s.data.stage - 1}`}>
            <a class="panel corner-brackets pcard" href={`/tutorial/${s.id.replace(/^en\//, '')}/`}>
              <span class="pix num">{String(s.data.stage).padStart(2, '0')}</span>
              <span class="pmain">
                <span class="ptitle">{s.data.title}</span>
                <span class="pq">{s.data.question}</span>
                <span class="pio">
                  <span class="pio-row"><span class="k">you learn</span> {s.data.objective}</span>
                  <span class="pio-row"><span class="k">produces</span> {s.data.produces}</span>
                </span>
                <span class="pmeta num">{s.data.runtime}</span>
              </span>
              <span class="pgo" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>

      <p class="pnote">
        Source for all three programs:
        <a href={FAMILY_URL}>examples/avionics_examples/cfd/plasma_blackout/ <span aria-hidden="true">↗</span></a>
      </p>
    </section>
  </article>
</BaseLayout>

<style>
  .tpage { max-width: var(--w-panel); }
  .thead { margin-bottom: var(--space-8); }
  .thead h1 { margin: var(--space-3) 0 var(--space-4); }
  .thead .lede { color: var(--fg-1); max-width: var(--measure); margin: 0; }

  .tsection { margin-bottom: var(--space-8); }
  .tsection h2 {
    font-size: var(--t-h3);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--line-1);
    margin-bottom: var(--space-5);
  }

  .pipeline { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--space-4); }
  /* The connector: what one walk produces, the next consumes. */
  .pstage + .pstage { position: relative; margin-top: var(--space-4); }
  .pstage + .pstage::before {
    content: '';
    position: absolute;
    top: calc(-1 * var(--space-4) - var(--space-2));
    left: var(--space-6);
    width: 1px;
    height: calc(var(--space-4) + var(--space-2) * 2);
    background: var(--line-2);
  }

  .pcard {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-5);
    color: var(--fg-0);
    border-bottom: 1px solid var(--line-1);
    transition: border-color var(--dur-fast) var(--ease-out),
                background-color var(--dur-fast) var(--ease-out);
  }
  .pcard:hover {
    border-color: var(--line-2);
    background-color: color-mix(in srgb, var(--accent) 5%, transparent);
  }
  .pix { color: var(--fg-2); }
  .pmain { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .ptitle { font-weight: var(--fw-heading); font-size: var(--t-h4); }
  .pq { color: var(--fg-1); font-size: var(--t-body-sm); max-width: var(--measure); }
  .pio { display: grid; gap: var(--space-1); margin-top: var(--space-1); }
  .pio-row { color: var(--fg-1); font-size: var(--t-body-sm); }
  .pio .k {
    font-family: var(--font-mono);
    font-size: var(--t-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-2);
    margin-right: var(--space-2);
  }
  .pmeta { color: var(--fg-2); font-size: var(--t-eyebrow); margin-top: var(--space-1); }
  .pgo { color: var(--accent); align-self: center; transition: transform var(--dur-fast) var(--ease-out); }
  .pcard:hover .pgo { transform: translateX(2px); }

  .pnote { color: var(--fg-1); font-size: var(--t-body-sm); margin: var(--space-5) 0 0; max-width: var(--measure); }

  .cmd {
    background: var(--bg-2);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin: 0 0 var(--space-4);
  }
  .cmd code { background: none; padding: 0; }
</style>
