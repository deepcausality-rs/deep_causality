---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/nav/SiteHeader.astro';
---
<BaseLayout
  title="Not found — DeepCausality CFD"
  description="That page does not exist."
  path="/404"
>
  <SiteHeader slot="header" />

  <article class="static-page">
    <header>
      <p class="eyebrow">404</p>
      <h1>Page not found</h1>
      <p class="lede">
        The requested page does not exist on this site.
      </p>
    </header>

    <ul class="hairline-list">
      <li><a href="/">Overview</a></li>
      <li><a href="/tutorial/">Tutorial</a></li>
      <li><a href="/blueprints/">Blueprints</a></li>
      <li><a href="/validation/">Validation status</a></li>
      <li><a href="/examples/">Worked examples</a></li>
      <li><a href="/boundaries/">Capability boundaries</a></li>
      <li><a href="/roadmap/">Roadmap</a></li>
    </ul>
  </article>
</BaseLayout>
