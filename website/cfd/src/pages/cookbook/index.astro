---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteHeader from '../../components/nav/SiteHeader.astro';
import { CRATE_URL } from '../../consts';

const title = 'Cookbook — DeepCausality CFD';
const description =
  'Task-shaped recipes: sweep a parameter and get a table, gate a run against a placard, fork a running simulation into counterfactual worlds, and pick a solver family.';

const recipes = (await getCollection('cookbook')).sort(
  (a, b) => a.data.order - b.data.order
);
---
<BaseLayout title={title} description={description} path="/cookbook/">
  <SiteHeader slot="header" />

  <article class="page cpage">
    <header class="chead">
      <p class="eyebrow">Cookbook</p>
      <h1>Task-oriented recipes</h1>
      <p class="lede">
        Each recipe covers one task, with the DSL verbs it uses and the worked
        examples that exercise it. Generated API documentation lives with the
        crate.
      </p>
    </header>

    <ol class="rlist">
      {recipes.map((r, i) => (
        <li class="ritem">
          <a href={`/cookbook/${r.id.replace(/^en\//, '')}/`}>
            <span class="rix num">{String(i).padStart(2, '0')}</span>
            <span class="rmain">
              <span class="rtitle">{r.data.title}</span>
              <span class="rtask">{r.data.task}</span>
              <span class="rsummary">{r.data.summary}</span>
              <span class="rverbs">
                {r.data.verbs.map((v) => <code>{v}</code>)}
              </span>
            </span>
            <span class="rgo" aria-hidden="true">→</span>
          </a>
        </li>
      ))}
    </ol>

    <p class="src-note">
      Full API reference lives with the source:
      <a href={CRATE_URL}>deep_causality_cfd <span aria-hidden="true">↗</span></a>
    </p>
  </article>
</BaseLayout>

<style>
  .cpage { max-width: var(--w-panel); }
  .chead { margin-bottom: var(--space-7); }
  .chead h1 { margin: var(--space-3) 0 var(--space-4); }
  .chead .lede { color: var(--fg-1); max-width: var(--measure); margin: 0; }

  .rlist { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--line-1); }
  .ritem { border-bottom: 1px solid var(--line-1); }
  .ritem a {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-4);
    align-items: start;
    padding: var(--space-5) var(--space-2);
    color: var(--fg-0);
    border-bottom: none;
    transform: translate3d(0, 0, 0);
    transition: transform var(--dur-med) var(--ease-out),
                background-color var(--dur-fast) var(--ease-out);
  }
  .ritem a:hover {
    transform: translate3d(var(--space-2), 0, 0);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
  }
  .rix { color: var(--fg-2); }
  .rmain { display: flex; flex-direction: column; gap: var(--space-2); min-width: 0; }
  .rtitle { font-weight: var(--fw-heading); font-size: var(--t-h4); }
  .rtask { color: var(--fg-0); font-size: var(--t-body-sm); }
  .rsummary { color: var(--fg-1); font-size: var(--t-body-sm); max-width: var(--measure); }
  .rverbs { display: flex; flex-wrap: wrap; gap: var(--space-2); margin-top: var(--space-1); }
  .rverbs code {
    font-size: var(--t-eyebrow);
    color: var(--fg-2);
    background: none;
    padding: 0;
  }
  .rverbs code::after { content: '·'; margin-left: var(--space-2); color: var(--line-2); }
  .rverbs code:last-child::after { content: ''; }
  .rgo { color: var(--accent); align-self: center; transition: transform var(--dur-fast) var(--ease-out); }
  .ritem a:hover .rgo { transform: translateX(2px); }

  .src-note { color: var(--fg-2); font-size: var(--t-body-sm); margin-top: var(--space-6); }
</style>
