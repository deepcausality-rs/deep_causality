  .axes { margin: 0 0 var(--space-4); display: grid; gap: var(--space-3); }
  .axis { padding-left: var(--space-4); border-left: 1px solid var(--line-2); }
  .axis dt { color: var(--fg-0); font-size: var(--t-body-sm); margin-bottom: var(--space-1); }
