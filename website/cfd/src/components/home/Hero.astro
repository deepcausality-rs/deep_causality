---
/**
 * Hero. Asymmetric 7fr/5fr split at ≥900px per DESIGN.md §8.2.
 *
 * Brand anchor note: the marketing site reads its mood from a raster
 * (frontpage-art.webp). No equivalent art exists for the CFD crate, so the
 * anchor here is a DRAWN flowfield in the shape every CFD reader expects:
 * streamlines around an airfoil. The wake carries the crate's thesis — the
 * trajectory reaches a fork node and splits into counterfactual worlds,
 * ghost branches dashed, the committed branch solid accent.
 *
 * The streamline dash drift is this page's single perpetual animation
 * (web_design/05-motion.md budget). It lives in the @keyframes themselves
 * (dasharray + dashoffset) so it wins over the global draw-in idiom by
 * cascade rule, not by selector specificity. Open-curve groups carry
 * fill="none" as a presentation attribute so a missed CSS rule can never
 * render them as filled black shapes. Everything structural enters through
 * the existing draw-in idiom (§12.10); no raster bytes; theme-aware for free.
 */
---
<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">DeepCausality · CFD</p>
      <h1>Counterfactual fluid dynamics</h1>
      <p class="tagline">
        A Rust crate that marches a compressible flow with plasma chemistry,
        navigation and control in one typed process, then forks the marched
        state to evaluate alternative commands.
      </p>
      <p class="sub">
        Three solver families share one interface and one scalar type. Figures
        on this site are quoted from committed run artifacts; capability limits
        are quoted from the studies that measured them.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href="/validation/">
          Validation status
          <span class="btn-ico" aria-hidden="true">→</span>
        </a>
        <a class="btn btn-ghost" href="/blueprints/">
          Blueprints
        </a>
      </div>

      <dl class="hero-facts">
        <div>
          <dt>Reference case</dt>
          <dd><span class="num">L1 ≤ 0.027</span> against the exact Riemann solution</dd>
        </div>
        <div>
          <dt>Flight anchor</dt>
          <dd><span class="num">+0.0 dec</span> vs RAM-C II peak electron density</dd>
        </div>
        <div>
          <dt>Counterfactual fork</dt>
          <dd><span class="num">42 ns</span> to fork a marched state, copy-on-write</dd>
        </div>
      </dl>
    </div>

    <div class="hero-art reticle-host">
      <span class="reticle reticle-tl"></span>
      <span class="reticle reticle-tr"></span>
      <span class="reticle reticle-bl"></span>
      <span class="reticle reticle-br"></span>

      <svg viewBox="0 0 340 300" role="img" data-anim-draw
           aria-label="Schematic of airflow around an airfoil: streamlines bend over and under the body, and downstream of the trailing edge the wake trajectory forks at a node into counterfactual branches — ghost branches dashed, the committed branch solid.">
        <!-- Computational-domain grid, faint. -->
        <g class="cgrid" fill="none">
          <line x1="36"  y1="16" x2="36"  y2="284" pathLength="100" />
          <line x1="116" y1="16" x2="116" y2="284" pathLength="100" />
          <line x1="296" y1="16" x2="296" y2="284" pathLength="100" />
        </g>

        <!-- Streamlines: dash drift in the flow direction, faster over the
             suction side than under the pressure side. -->
        <g class="stream" fill="none">
          <path class="s-fast" d="M 6 40 C 90 40, 150 35, 210 35 C 260 35, 300 37, 334 38" />
          <path class="s-fast" d="M 6 75 C 80 75, 120 66, 170 61 C 220 58, 280 66, 334 69" />
          <path class="s-fast" d="M 6 110 C 64 110, 92 104, 124 99 C 168 93, 210 108, 244 120 C 274 129, 304 132, 334 131" />
          <path class="s-slow" d="M 6 150 C 30 150, 50 150, 66 151" />
          <path class="s-fast" d="M 6 143 C 44 143, 62 137, 76 129 C 92 121, 108 117, 130 117 C 170 116, 208 130, 238 143 C 262 152, 300 147, 334 144" />
          <path class="s-slow" d="M 6 159 C 50 159, 72 161, 94 162 C 130 164, 168 163, 204 159 C 232 155, 250 154, 262 155 C 292 157, 316 156, 334 155" />
          <path class="s-slow" d="M 6 190 C 64 190, 94 194, 126 198 C 168 203, 214 194, 250 182 C 284 172, 312 169, 334 168" />
          <path class="s-slow" d="M 6 225 C 90 225, 160 229, 220 227 C 270 225, 306 221, 334 219" />
          <path class="s-slow" d="M 6 260 C 100 260, 200 259, 334 256" />
        </g>

        <!-- The vehicle: a cambered airfoil at slight incidence. -->
        <path class="foil" d="M 70 151 C 74 138, 96 128, 126 127 C 166 126, 204 136, 226 146 C 196 152, 150 156, 112 155 C 88 154, 74 156, 70 151 Z" pathLength="100" />

        <!-- The marched trajectory: trailing edge to the fork point, then the
             committed world, drawn solid. -->
        <g class="commit" fill="none">
          <path d="M 226 146 C 238 148, 248 150, 257 150" pathLength="100" />
          <path d="M 258 150 C 282 148, 306 140, 330 132" pathLength="100" />
        </g>

        <!-- Counterfactual worlds: same fork point, dashed ghosts. -->
        <g class="ghosts" fill="none">
          <path d="M 258 150 C 280 142, 304 122, 326 104" />
          <path d="M 258 150 C 282 156, 306 164, 330 172" />
          <path d="M 258 150 C 280 158, 302 182, 322 206" />
        </g>

        <!-- Fork node and world endpoints. -->
        <g class="nodes">
          <circle class="n-fork" cx="258" cy="150" r="3" />
          <circle class="n-commit" cx="330" cy="132" r="2.5" />
          <circle class="n-ghost" cx="326" cy="104" r="2" />
          <circle class="n-ghost" cx="330" cy="172" r="2" />
          <circle class="n-ghost" cx="322" cy="206" r="2" />
        </g>
      </svg>

      <figcaption class="art-caption">
        <span class="k">fork</span> 42 ns
        <span class="sep" aria-hidden="true">·</span>
        <span class="k">worlds</span> 17
        <span class="sep" aria-hidden="true">·</span>
        <span class="k">Δv vs frozen drag</span> 139.4 m/s
      </figcaption>
    </div>
  </div>
</section>

<style>
  .hero { padding: var(--space-7) var(--space-4) var(--space-8); }
  @media (min-width: 720px) { .hero { padding: var(--space-8) var(--space-5) var(--space-9); } }

  .hero-inner {
    max-width: var(--w-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-inner { grid-template-columns: 7fr 5fr; gap: var(--space-8); }
  }

  /* Art above text on narrow screens, capped so it stays an emblem rather
     than a full-bleed poster; back to the right column at ≥900px. */
  .hero-art {
    order: -1;
    width: 100%;
    max-width: 420px;
    margin-inline: auto;
  }
  @media (min-width: 900px) {
    .hero-art { order: 0; max-width: none; margin-inline: 0; }
  }

  h1 {
    font-size: clamp(2.25rem, 5.5vw + 0.5rem, 3.75rem);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    margin: var(--space-3) 0 var(--space-4);
    max-width: 18ch;
  }
  .tagline {
    font-size: var(--t-h3);
    line-height: var(--lh-h3);
    color: var(--fg-1);
    max-width: var(--measure-lede);
    margin: 0 0 var(--space-4);
  }
  .sub {
    color: var(--fg-1);
    font-size: var(--t-body-sm);
    max-width: var(--measure-lede);
    margin: 0 0 var(--space-6);
  }

  .cta-row { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-bottom: var(--space-7); }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 44px;
    padding: 0 var(--space-5);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-size: var(--t-body-sm);
    font-weight: var(--fw-heading);
    border-bottom: 1px solid transparent;
    transition: transform var(--dur-fast) var(--ease-out),
                background-color var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out);
  }
  .btn:active { transform: translateY(1px); }
  .btn-primary { background: var(--accent); color: var(--accent-ink); }
  .btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 90%, white);
    border-color: transparent;
    border-bottom-color: transparent;
  }
  .btn-ico { transition: transform var(--dur-fast) var(--ease-out); }
  .btn-primary:hover .btn-ico { transform: translateX(2px); }
  .btn-ghost { color: var(--fg-0); border-color: var(--line-2); }
  .btn-ghost:hover {
    border-color: var(--fg-2);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-bottom-color: var(--fg-2);
  }

  .hero-facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--line-1);
  }
  @media (min-width: 600px) { .hero-facts { grid-template-columns: repeat(3, 1fr); } }
  .hero-facts dt {
    font-family: var(--font-mono);
    font-size: var(--t-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-2);
    margin-bottom: var(--space-2);
  }
  .hero-facts dd { margin: 0; color: var(--fg-1); font-size: var(--t-body-sm); }
  .hero-facts .num { color: var(--accent); }

  /* --- The drawn flowfield --- */
  .hero-art {
    background-image: linear-gradient(180deg,
      color-mix(in srgb, var(--bg-1) 70%, transparent) 0%,
      var(--bg-1) 100%);
    border: 1px solid var(--line-1);
    border-radius: var(--radius-lg);
    /* --shadow-2 plus the documented hero accent halo
       (web_design/04-surface.md: 80px blur, ~⅓ negative spread). */
    box-shadow: var(--shadow-2),
                0 0 80px -28px color-mix(in srgb, var(--accent) 38%, transparent);
    padding: var(--space-5);
  }
  /* The reticle radius must match its host (DESIGN.md §12.3). */
  .hero-art > .reticle-tl { border-top-left-radius: var(--radius-lg); }
  .hero-art > .reticle-tr { border-top-right-radius: var(--radius-lg); }
  .hero-art > .reticle-bl { border-bottom-left-radius: var(--radius-lg); }
  .hero-art > .reticle-br { border-bottom-right-radius: var(--radius-lg); }

  .hero-art svg { display: block; width: 100%; height: auto; overflow: visible; }

  .cgrid line {
    stroke: var(--line-1);
    stroke-width: 1;
    opacity: 0.7;
    vector-effect: non-scaling-stroke;
  }

  /* Streamlines carry the page's one perpetual animation: a dash drift in
     the flow direction. The dash pattern lives inside the keyframes so the
     running animation overrides the global draw-in idiom's dasharray by
     cascade rule. Suction side drifts faster than pressure side. */
  .hero .hero-art .stream path {
    stroke: var(--fg-2);
    stroke-width: 1;
    opacity: 0.55;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 7 6;
    stroke-dashoffset: 0;
  }
  .hero .hero-art .stream .s-fast { animation: flow 1400ms linear infinite; }
  .hero .hero-art .stream .s-slow { animation: flow 2100ms linear infinite; }
  @keyframes flow {
    from { stroke-dasharray: 7 6; stroke-dashoffset: 13; }
    to   { stroke-dasharray: 7 6; stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero .hero-art .stream path { animation: none; }
  }

  .foil {
    fill: color-mix(in srgb, var(--bg-3) 85%, transparent);
    stroke: var(--line-2);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }

  .commit path {
    stroke: var(--accent);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }

  /* Ghost worlds: dashed, entering on a fade rather than the draw-in, since
     the draw-in would overwrite their dash pattern. */
  .hero .hero-art .ghosts { opacity: 0; transition: opacity var(--dur-draw) var(--ease-out) calc(var(--dur-draw) * 0.6); }
  .hero .hero-art svg.in-view .ghosts { opacity: 1; }
  .hero .hero-art .ghosts path {
    stroke: var(--fg-2);
    stroke-width: 1;
    opacity: 0.65;
    stroke-dasharray: 2 4;
    stroke-dashoffset: 0;
    vector-effect: non-scaling-stroke;
  }
  @media (prefers-reduced-motion: reduce) {
    .hero .hero-art .ghosts { opacity: 1; }
  }

  .nodes .n-fork   { fill: var(--accent); }
  .nodes .n-commit { fill: var(--accent); }
  .nodes .n-ghost  { fill: var(--fg-2); }

  .art-caption {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--line-1);
    font-family: var(--font-mono);
    font-size: var(--t-mono-sm);
    color: var(--fg-1);
  }
  .art-caption .k { color: var(--fg-2); }
  .art-caption .sep { color: var(--fg-2); }
</style>
