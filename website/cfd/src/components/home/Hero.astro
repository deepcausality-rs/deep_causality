---
/**
 * Hero. Asymmetric 7fr/5fr split at ≥900px per DESIGN.md §8.2.
 *
 * Brand anchor note: the marketing site reads its mood from a raster
 * (frontpage-art.webp). No equivalent art exists for the CFD crate, so the
 * anchor here is a DRAWN flowfield of the crate's own flight anchor — a
 * RAM-C-style sphere-cone at hypersonic speed. Layers, back to front: a faint
 * Cartesian grid in the freestream, the plasma-sheath wash, the shock-fitted
 * coordinate fan (the crate's body-fitted story, drawn literally), the
 * detached bow shock, the capsule, and the sampled stagnation line.
 *
 * Streamlines kink where they cross the shock and their dash pattern
 * compresses and slows downstream of it — the Rankine–Hugoniot deflection and
 * the velocity drop, drawn rather than stated. The dash drift is this page's
 * single perpetual animation (web_design/05-motion.md budget); everything
 * structural enters through the existing draw-in idiom (§12.10). Built from
 * the same hairline/node vocabulary as the rest of the site (§12), costs no
 * raster bytes, and is theme-aware for free.
 */
---
<section class="hero">
  <div class="hero-inner">
    <div class="hero-copy">
      <p class="eyebrow">DeepCausality · CFD</p>
      <h1>Counterfactual fluid dynamics</h1>
      <p class="tagline">
        A Rust crate that marches a compressible flow with plasma chemistry,
        navigation and control in one typed process, then forks the marched
        state to evaluate alternative commands.
      </p>
      <p class="sub">
        Three solver families share one interface and one scalar type. Figures
        on this site are quoted from committed run artifacts; capability limits
        are quoted from the studies that measured them.
      </p>

      <div class="cta-row">
        <a class="btn btn-primary" href="/validation/">
          Validation status
          <span class="btn-ico" aria-hidden="true">→</span>
        </a>
        <a class="btn btn-ghost" href="/blueprints/">
          Blueprints
        </a>
      </div>

      <dl class="hero-facts">
        <div>
          <dt>Reference case</dt>
          <dd><span class="num">L1 ≤ 0.027</span> against the exact Riemann solution</dd>
        </div>
        <div>
          <dt>Flight anchor</dt>
          <dd><span class="num">+0.0 dec</span> vs RAM-C II peak electron density</dd>
        </div>
        <div>
          <dt>Counterfactual fork</dt>
          <dd><span class="num">42 ns</span> to fork a marched state, copy-on-write</dd>
        </div>
      </dl>
    </div>

    <div class="hero-art reticle-host">
      <span class="reticle reticle-tl"></span>
      <span class="reticle reticle-tr"></span>
      <span class="reticle reticle-bl"></span>
      <span class="reticle reticle-br"></span>

      <svg viewBox="0 0 340 300" role="img" data-anim-draw
           aria-label="Schematic of a reentry capsule in hypersonic flow: a detached bow shock stands off the spherical nose, freestream streamlines deflect where they cross it, a shock-fitted coordinate fan spans the plasma sheath, and the stagnation line is sampled with three nodes.">
        <!-- Freestream Cartesian grid: the capture coordinate, deliberately
             faint against the fitted fan inside the sheath. -->
        <g class="cgrid">
          <line x1="36"  y1="16" x2="36"  y2="284" pathLength="100" />
          <line x1="76"  y1="16" x2="76"  y2="284" pathLength="100" />
          <line x1="116" y1="16" x2="116" y2="284" pathLength="100" />
        </g>

        <!-- Plasma sheath between shock and body. -->
        <path class="sheath" d="M 204 12 C 158 64, 146 114, 146 150 C 146 186, 158 236, 204 288 L 210 186 A 36 36 0 0 1 210 114 Z" />

        <!-- Shock-fitted coordinate fan: surface normals plus one shell,
             the body-fitted grid the QTT marcher aligns to. -->
        <g class="fan">
          <line x1="179" y1="132" x2="149" y2="115" pathLength="100" />
          <line x1="192" y1="119" x2="164" y2="75"  pathLength="100" />
          <line x1="179" y1="168" x2="149" y2="185" pathLength="100" />
          <line x1="192" y1="181" x2="164" y2="225" pathLength="100" />
          <path class="shell" d="M 196 84 C 166 108, 156 128, 156 150 C 156 172, 166 192, 196 216" pathLength="100" />
        </g>

        <!-- Freestream streamlines: straight, wide dashes, fast drift. -->
        <g class="stream-pre">
          <path d="M 6 30 H 190" />
          <path d="M 6 70 H 165" />
          <path d="M 6 110 H 151" />
          <path d="M 6 150 H 146" />
          <path d="M 6 190 H 151" />
          <path d="M 6 230 H 165" />
          <path d="M 6 270 H 190" />
        </g>

        <!-- Post-shock streamlines: deflected at the crossing, denser dashes,
             slower drift — compression and deceleration across the shock. -->
        <g class="stream-post">
          <path d="M 190 30 C 230 26, 270 22, 334 20" />
          <path d="M 165 70 C 200 62, 240 50, 334 42" />
          <path d="M 151 110 C 176 102, 196 88, 216 78 C 248 64, 290 58, 334 55" />
          <path d="M 151 190 C 176 198, 196 212, 216 222 C 248 236, 290 242, 334 245" />
          <path d="M 165 230 C 200 238, 240 250, 334 258" />
          <path d="M 190 270 C 230 274, 270 278, 334 280" />
        </g>

        <!-- The detached bow shock: a soft density band under a sharp line. -->
        <path class="shock-under" d="M 204 12 C 158 64, 146 114, 146 150 C 146 186, 158 236, 204 288" pathLength="100" />
        <path class="shock" d="M 204 12 C 158 64, 146 114, 146 150 C 146 186, 158 236, 204 288" pathLength="100" />

        <!-- Sphere-cone forebody. No wake is drawn: the wake is out of scope
             for the fitted marchers, and the figure keeps to what is claimed. -->
        <path class="body" d="M 310 90 L 210 114 A 36 36 0 0 0 210 186 L 310 210 Z" pathLength="100" />

        <!-- Marched stagnation line with sample nodes. -->
        <line class="stagline" x1="146" y1="150" x2="174" y2="150" pathLength="100" />
        <g class="nodes">
          <circle cx="146" cy="150" r="3" />
          <circle cx="160" cy="150" r="3" />
          <circle cx="174" cy="150" r="3" />
        </g>
      </svg>

      <figcaption class="art-caption">
        <span class="k">case</span> RAM-C II
        <span class="sep" aria-hidden="true">·</span>
        <span class="k">standoff</span> 7.6 mm
        <span class="sep" aria-hidden="true">·</span>
        <span class="k">T₂</span> 8044 K
        <span class="sep" aria-hidden="true">·</span>
        <span class="k">n_e</span> 1.085e19 m⁻³
      </figcaption>
    </div>
  </div>
</section>

<style>
  .hero { padding: var(--space-7) var(--space-4) var(--space-8); }
  @media (min-width: 720px) { .hero { padding: var(--space-8) var(--space-5) var(--space-9); } }

  .hero-inner {
    max-width: var(--w-wide);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  @media (min-width: 900px) {
    .hero-inner { grid-template-columns: 7fr 5fr; gap: var(--space-8); }
  }

  /* Art above text on narrow screens; back to the right column at ≥900px. */
  .hero-art { order: -1; }
  @media (min-width: 900px) { .hero-art { order: 0; } }

  h1 {
    font-size: clamp(2.25rem, 5.5vw + 0.5rem, 3.75rem);
    line-height: var(--lh-display);
    letter-spacing: var(--ls-display);
    margin: var(--space-3) 0 var(--space-4);
    max-width: 18ch;
  }
  .tagline {
    font-size: var(--t-h3);
    line-height: var(--lh-h3);
    color: var(--fg-1);
    max-width: var(--measure-lede);
    margin: 0 0 var(--space-4);
  }
  .sub {
    color: var(--fg-1);
    font-size: var(--t-body-sm);
    max-width: var(--measure-lede);
    margin: 0 0 var(--space-6);
  }

  .cta-row { display: flex; flex-wrap: wrap; gap: var(--space-3); margin-bottom: var(--space-7); }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 44px;
    padding: 0 var(--space-5);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    font-size: var(--t-body-sm);
    font-weight: var(--fw-heading);
    border-bottom: 1px solid transparent;
    transition: transform var(--dur-fast) var(--ease-out),
                background-color var(--dur-fast) var(--ease-out),
                border-color var(--dur-fast) var(--ease-out),
                color var(--dur-fast) var(--ease-out);
  }
  .btn:active { transform: translateY(1px); }
  .btn-primary { background: var(--accent); color: var(--accent-ink); }
  .btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 90%, white);
    border-color: transparent;
    border-bottom-color: transparent;
  }
  .btn-ico { transition: transform var(--dur-fast) var(--ease-out); }
  .btn-primary:hover .btn-ico { transform: translateX(2px); }
  .btn-ghost { color: var(--fg-0); border-color: var(--line-2); }
  .btn-ghost:hover {
    border-color: var(--fg-2);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-bottom-color: var(--fg-2);
  }

  .hero-facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    margin: 0;
    padding-top: var(--space-5);
    border-top: 1px solid var(--line-1);
  }
  @media (min-width: 600px) { .hero-facts { grid-template-columns: repeat(3, 1fr); } }
  .hero-facts dt {
    font-family: var(--font-mono);
    font-size: var(--t-eyebrow);
    letter-spacing: var(--ls-eyebrow);
    text-transform: uppercase;
    color: var(--fg-2);
    margin-bottom: var(--space-2);
  }
  .hero-facts dd { margin: 0; color: var(--fg-1); font-size: var(--t-body-sm); }
  .hero-facts .num { color: var(--accent); }

  /* --- The drawn flowfield --- */
  .hero-art {
    background-image: linear-gradient(180deg,
      color-mix(in srgb, var(--bg-1) 70%, transparent) 0%,
      var(--bg-1) 100%);
    border: 1px solid var(--line-1);
    border-radius: var(--radius-lg);
    /* --shadow-2 plus the documented hero accent halo
       (web_design/04-surface.md: 80px blur, ~⅓ negative spread). */
    box-shadow: var(--shadow-2),
                0 0 80px -28px color-mix(in srgb, var(--accent) 38%, transparent);
    padding: var(--space-5);
  }
  /* The reticle radius must match its host (DESIGN.md §12.3). */
  .hero-art > .reticle-tl { border-top-left-radius: var(--radius-lg); }
  .hero-art > .reticle-tr { border-top-right-radius: var(--radius-lg); }
  .hero-art > .reticle-bl { border-bottom-left-radius: var(--radius-lg); }
  .hero-art > .reticle-br { border-bottom-right-radius: var(--radius-lg); }

  .hero-art svg { display: block; width: 100%; height: auto; overflow: visible; }

  .cgrid line {
    stroke: var(--line-1);
    stroke-width: 1;
    opacity: 0.6;
    vector-effect: non-scaling-stroke;
  }

  /* Streamlines opt OUT of the draw-in idiom (which would overwrite their
     dash pattern) and carry the page's one perpetual animation instead:
     a slow dash drift in the flow direction. Selector specificity beats
     `[data-anim-draw].in-view path` on purpose. */
  .hero-art [data-anim-draw] .stream-pre path {
    fill: none;
    stroke: var(--fg-2);
    stroke-width: 1;
    opacity: 0.45;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 7 6;
    stroke-dashoffset: 0;
    animation: flow-pre 1500ms linear infinite;
  }
  .hero-art [data-anim-draw] .stream-post path {
    fill: none;
    stroke: var(--fg-2);
    stroke-width: 1;
    opacity: 0.8;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 4 4;
    stroke-dashoffset: 0;
    animation: flow-post 2600ms linear infinite;
  }
  /* One dash period per cycle keeps the loop seamless: 13 = 7+6, 8 = 4+4. */
  @keyframes flow-pre  { to { stroke-dashoffset: -13; } }
  @keyframes flow-post { to { stroke-dashoffset: -8; } }
  @media (prefers-reduced-motion: reduce) {
    .hero-art [data-anim-draw] .stream-pre path,
    .hero-art [data-anim-draw] .stream-post path { animation: none; }
  }

  .sheath {
    fill: color-mix(in srgb, var(--accent) 7%, transparent);
    stroke: none;
    opacity: 0;
    transition: opacity var(--dur-draw) var(--ease-out);
    transition-delay: calc(var(--dur-draw) * 0.4);
  }
  .hero-art svg.in-view .sheath { opacity: 1; }
  @media (prefers-reduced-motion: reduce) { .sheath { opacity: 1; } }

  .fan line, .fan .shell {
    fill: none;
    stroke: var(--line-2);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .fan line { opacity: 0.8; }
  .fan .shell { opacity: 0.5; }

  .shock-under {
    fill: none;
    stroke: var(--accent);
    stroke-width: 4;
    opacity: 0.18;
    vector-effect: non-scaling-stroke;
  }
  .shock {
    fill: none;
    stroke: var(--accent);
    stroke-width: 1.5;
    vector-effect: non-scaling-stroke;
  }
  .body {
    fill: color-mix(in srgb, var(--bg-3) 80%, transparent);
    stroke: var(--line-2);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .hero-art [data-anim-draw] .stagline {
    stroke: var(--accent);
    stroke-width: 1;
    stroke-dasharray: 3 3;
    stroke-dashoffset: 0;
    opacity: 0.8;
    vector-effect: non-scaling-stroke;
  }
  .nodes circle { fill: var(--accent); }

  .art-caption {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: baseline;
    margin-top: var(--space-4);
    padding-top: var(--space-3);
    border-top: 1px solid var(--line-1);
    font-family: var(--font-mono);
    font-size: var(--t-mono-sm);
    color: var(--fg-1);
  }
  .art-caption .k { color: var(--fg-2); }
  .art-caption .sep { color: var(--fg-2); }
</style>
