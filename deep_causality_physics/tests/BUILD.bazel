load("@rules_rust//rust:defs.bzl", "rust_test_suite")

# =============================================================================
# constants/* test suites
#
# The src tree is organized as src/constants/<type>/, so the tests mirror it
# at tests/constants/<type>/.
# =============================================================================

rust_test_suite(
    name = "constants",
    srcs = glob([
        "constants/*_tests.rs",
    ]),
    crate_features = [
        "std",
        "alloc",
    ],
    tags = [
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//deep_causality_physics",
        # Internal dependencies
    ],
)

