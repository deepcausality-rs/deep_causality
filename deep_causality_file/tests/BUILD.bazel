load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "errors",
    srcs = glob([
        "errors/*_tests.rs",
    ]),
    tags = [
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//deep_causality_file",
    ],
)

