"""rules_astro — build Astro sites hermetically under Bazel (astro_site / astro_dev).

Wraps the node toolchain via aspect_rules_js so `astro build` runs as a Bazel
action (RBE-eligible), producing a static dist/ tree. Generic — no fastverk
coupling; reusable for any Astro site, docs portal, or blog.
"""
module(
    name = "rules_astro",
    version = "0.0.1",
    compatibility_level = 1,
)

bazel_dep(name = "aspect_rules_js", version = "2.1.3")
bazel_dep(name = "rules_nodejs", version = "6.3.0")
bazel_dep(name = "bazel_skylib", version = "1.7.1")
bazel_dep(name = "platforms", version = "0.0.10")

# The node version is pinned by the consumer's toolchain; documented in README.
