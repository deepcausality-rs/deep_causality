load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "algebra",
    srcs = glob([
        "algebra/*_tests.rs",
    ]),
    tags = [
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//deep_causality_haft",
    ],
)

