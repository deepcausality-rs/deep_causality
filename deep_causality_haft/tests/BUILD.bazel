rust_test_suite(
    name = "formalization_lean",
    srcs = glob([
        "formalization_lean/*_tests.rs",
    ]),
    # `free_monad_tests` is gated behind `alloc` (it uses the alloc-only `Free`/`FreeWitness`);
    # set the feature so it is compiled and run under Bazel, not silently skipped.
    crate_features = [
        "std",
        "alloc",
    ],
    tags = [
        "lean-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//deep_causality_algebra",
        "//deep_causality_haft",
    ],
)

