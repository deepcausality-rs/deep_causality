load("@rules_rust//rust:defs.bzl", "rust_test")

# =============================================================================
# tests mirror the src tree: tests/coordinate/, tests/navigation/,
# tests/solvers/, tests/tensor_bridge/, tests/theories/, tests/types/.
#
# Each subtree is registered through its own mod.rs aggregator and shares
# parent-module helpers (e.g. `super::run_march` in types/flow/mod.rs), so it
# is compiled as a test binary rooted at that mod.rs rather than as standalone
# per-file tests. The `*_tests.rs` glob does not match the mod.rs aggregators,
# so each suite lists the mod.rs crate roots it needs explicitly.
#
# Subtrees that contain sub-folders are split into one suite per sub-folder,
# named `<folder>_<subfolder>` (e.g. `solvers_dec`, `types_flow`). The suites
# are kept in alphabetical order, matching the source tree.
# =============================================================================

rust_test(
    name = "coordinate",
    srcs = glob([
        "coordinate/*_tests.rs",
    ]) + [
        "coordinate/mod.rs",
    ],
    crate_features = [
        "std",
    ],
    crate_root = "coordinate/mod.rs",
    tags = [
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//deep_causality_cfd",
        # Internal dependencies
        "//deep_causality_physics",
        "//deep_causality_tensor",
    ],
)

